# ─────────────────────────────────────────────────────────
#  Environment Variables — CIBIL Automation Server
#  Copy this file as .env for local use,
#  OR set these as environment variables in your cloud dashboard
#  (Railway / Render / Fly.io / etc.)
#
#  IMPORTANT: Never commit .env or real credentials to Git!
# ─────────────────────────────────────────────────────────

# ── OpenAI API Key (REQUIRED for AI document extraction) ─
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# ── Chrome / Selenium ─────────────────────────────────────
# Set to "true" for cloud/server, "false" for local (shows browser window)
HEADLESS=false

# Path to Chromium binary (auto-detected if not set)
# CHROMIUM_PATH=/usr/bin/chromium

# Path to ChromeDriver (auto-downloaded if not set)
# CHROMEDRIVER_PATH=/usr/bin/chromedriver

# Directory where downloaded reports are saved
# Default: ./reports (local) or /tmp/cibil_reports (cloud)
# DOWNLOAD_DIR=/tmp/cibil_reports

# ── Flask Server ──────────────────────────────────────────
PORT=5000

# ── CIBIL Credentials (OPTIONAL — recommended to leave blank) ─
# If set, these are used as fallback when browser does not send credentials.
# SECURITY: Leave blank for cloud deployment — let users send creds per-session
# from their browser (stored in browser localStorage only).
# CIBIL_USERNAME=
# CIBIL_PASSWORD=
